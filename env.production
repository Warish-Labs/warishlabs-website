# ==============================================================================
# WARISHLABS WEBSITE - PRODUCTION ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy these settings to your deployment dashboard (e.g. Vercel, Neon, Supabase)
# NEVER commit your actual production secrets to git repository.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. PostgreSQL Database Configuration
# ------------------------------------------------------------------------------
# PostgreSQL pooled connection URL (Neon or Supabase connection pooler)
DATABASE_URL="postgresql://[user]:[password]@[host]-pooler.[region].aws.neon.tech/[dbname]?sslmode=require"

# PostgreSQL direct connection URL (required for migrations only)
DIRECT_URL="postgresql://[user]:[password]@[host].[region].aws.neon.tech/[dbname]?sslmode=require"

# ------------------------------------------------------------------------------
# 2. Clerk Authentication Keys (Production instance)
# ------------------------------------------------------------------------------
# Public publishable key for Clerk widgets and SDK calls
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."

# Clerk Secret Key for backend authentication and JWT verification
CLERK_SECRET_KEY="sk_live_..."

# Clerk Redirection endpoints
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/admin/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/admin/login"

# ------------------------------------------------------------------------------
# 3. Super Administrative Filter
# ------------------------------------------------------------------------------
# The exact email address of the owner account.
# Anyone authenticating with this email via Clerk will be assigned Super Admin.
ADMIN_EMAIL="warishlabs@gmail.com"

# ------------------------------------------------------------------------------
# 4. App URL Config
# ------------------------------------------------------------------------------
# The verified canonical domain name (no trailing slash, e.g. https://warishlabs.in)
NEXT_PUBLIC_APP_URL="https://warishlabs.in"

# ------------------------------------------------------------------------------
# 5. Media Storage (Cloudinary Credentials)
# ------------------------------------------------------------------------------
# Your Cloudinary details from console dashboard
CLOUDINARY_CLOUD_NAME="[your_cloud_name]"
CLOUDINARY_API_KEY="[your_api_key]"
CLOUDINARY_API_SECRET="[your_api_secret]"

# ------------------------------------------------------------------------------
# 6. Transactional Mail (Resend Settings)
# ------------------------------------------------------------------------------
# Resend API key for contact form delivery and newsletter welcome emails
RESEND_API_KEY="re_..."

# ------------------------------------------------------------------------------
# 7. Global Caching & DDoS rate-limiting (Upstash Redis)
# ------------------------------------------------------------------------------
# Upstash Redis connection parameters (starts with rediss://)
UPSTASH_REDIS_REST_URL="https://[your_db]-us1.upstash.io"
UPSTASH_REDIS_REST_TOKEN="[your_token]"
