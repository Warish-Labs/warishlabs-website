generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activityLogs ActivityLog[]
  sessions     Session[]
}

model Session {
  id        String   @id @default(uuid())
  adminId   String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

model Category {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  seo         CategorySEO?
  products    Product[]
}

model CategorySEO {
  id          String   @id @default(uuid())
  categoryId  String   @unique
  title       String
  description String
  keywords    String?
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model Product {
  id             String              @id @default(uuid())
  name           String
  slug           String              @unique
  tagline        String
  description    String              @db.Text // HTML or Rich Text from Tiptap
  status         String // "active", "beta", "archived"
  type           String              @default("Tool")
  githubUrl      String?
  visitUrl       String?
  logoUrl        String?
  bannerUrl      String?
  featured       Boolean             @default(false)
  showOnHomepage Boolean             @default(false)
  displayOrder   Int                 @default(0)
  categoryId     String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  category       Category            @relation(fields: [categoryId], references: [id])
  faqs           ProductFAQ[]
  media          ProductMedia[]
  seo            ProductSEO?
  technologies   ProductTechnology[]

  @@index([categoryId])
}

model Technology {
  id        String              @id @default(uuid())
  name      String
  slug      String              @unique
  icon      String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  products  ProductTechnology[]
}

model ProductTechnology {
  productId    String
  technologyId String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([productId, technologyId])
  @@index([technologyId])
}

model ProductMedia {
  id        String   @id @default(uuid())
  productId String
  url       String
  type      String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductSEO {
  id          String  @id @default(uuid())
  productId   String  @unique
  title       String
  description String
  keywords    String?
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Blog {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  content     String
  excerpt     String
  coverImage  String?
  category    String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  seo         BlogSEO?
}

model BlogSEO {
  id          String  @id @default(uuid())
  blogId      String  @unique
  title       String
  description String
  keywords    String?
  blog        Blog    @relation(fields: [blogId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("unread")
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  active    Boolean  @default(true)
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Visitor {
  id        String           @id @default(uuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  events    AnalyticsEvent[]
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  visitorId String
  eventName String
  eventData Json?
  url       String
  referrer  String?
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())
  visitor   Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  @@index([visitorId])
  @@index([createdAt])
}

model MediaAsset {
  id        String   @id @default(uuid())
  url       String
  publicId  String   @unique
  fileName  String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())
}

model NavItem {
  id        String    @id @default(uuid())
  label     String
  path      String
  parentId  String?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  parent    NavItem?  @relation("NavHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  NavItem[] @relation("NavHierarchy")

  @@index([parentId])
}

model SiteSetting {
  id        String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductFAQ {
  id        String   @id @default(uuid())
  productId String
  question  String
  answer    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Lab {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  url         String? // liveUrl
  githubUrl   String? // repoUrl
  demoUrl     String?
  mediaUrl    String? // Cloudinary upload
  status      String // "active", "completed", "deprecated"
  type        String   @default("experiment") // open source / experiment / tool / sandbox
  techStack   String? // comma-separated tags
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OpenSourceProject {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String
  githubUrl   String
  stars       Int      @default(0)
  forks       Int      @default(0)
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HomepageSection {
  id          String   @id @default(uuid())
  sectionType String   @unique
  title       String?
  subtitle    String?
  config      Json
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(uuid())
  platform  String   @unique
  url       String?
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
