# WarishLabs Environment Variables Template

# 1. Database (PostgreSQL)
# Local Dev Example: postgresql://postgres:Warish@786@localhost:5432/warishlabs?schema=public
# Production Example (Neon): postgresql://[user]:[password]@[neon-hostname]/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:Warish@786@localhost:5432/warishlabs?schema=public"

ADMIN_EMAIL="warishlabs@gmail.com"

# 3. Media Service (Cloudinary)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# 4. Email Service (Resend)
RESEND_API_KEY="re_your_resend_api_key"

# 5. Security & System
# Token used to secure the daily CRON cleanup endpoint
CRON_SECRET="your_secure_random_cron_secret"

# 6. Rate Limiting (Upstash Redis - optional for development fallback)
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token"
